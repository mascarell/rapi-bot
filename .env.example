NODE_ENV=development
WAIFUPORT=app port
WAIFUTOKEN=discord token
CATAPI=thecatapi.com token
CLIENTID=client id from OAuth2 discord dev portal
S3BUCKET=S3 bucket name
S3ACCESSKEYID=S3 access key id
S3SECRETKEY=S3 secret access key
CDN_DOMAIN_URL=CDN domain url
TWITCH_CLIENT_ID=twitch api client id
TWITCH_CLIENT_SECRET=twitch api client secret

# PostgreSQL (optional — omit for S3-only mode)
DATABASE_URL=postgresql://rapibot_dev:<password>@localhost:5432/rapibot_dev
# Storage mode: s3-only | dual-write-s3-primary | dual-write-pg-primary | pg-only
STORAGE_MODE=s3-only
# Per-service overrides (optional)
# STORAGE_NOTIFICATIONS=pg-only
# STORAGE_GUILD_CONFIG=s3-only
# STORAGE_VOTES=s3-only
# STORAGE_GACHA=s3-only